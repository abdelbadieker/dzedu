# =============================================================================
# DzEdu Environment Variables
# =============================================================================

# --- App ---
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/dzedu?schema=public

# --- NextAuth.js (Auth.js v5) ---
AUTH_SECRET=your-256-bit-secret-change-in-production
AUTH_URL=http://localhost:3000/api/auth

# --- OAuth Providers ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- OTP (Crypto) ---
OTP_SECRET=your-otp-hmac-secret-change-in-production

# --- Email (Nodemailer) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@dzedu.dz

# --- Chargily Pay (Algerian Payments) ---
CHARGILY_API_KEY=your-chargily-api-key
CHARGILY_WEBHOOK_SECRET=your-chargily-webhook-secret
CHARGILY_MODE=EDU

# --- Stripe (International Payments) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_SKILLS_MONTHLY=price_...

# --- CDN / Video Streaming ---
CDN_URL=https://your-cdn.bunny.net
CDN_API_KEY=your-cdn-api-key
CDN_TOKEN_EXPIRY_SECONDS=3600

# --- Security ---
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
MAX_CONCURRENT_DEVICES=2

# --- Sentry (Error Monitoring) ---
SENTRY_DSN=https://your-dsn@oXXXXX.ingest.sentry.io/XXXXX
