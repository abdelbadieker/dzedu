{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "main": true,
      "develop": true
    }
  },
  "framework": "nextjs",
  "rootDirectory": "apps/web",
  "installCommand": "cd ../.. && npm ci --include-workspace-root",
  "buildCommand": "cd ../.. && npx prisma generate --schema=packages/database/prisma/schema.prisma && cd apps/web && npm run build",
  "outputDirectory": ".next"
}
